# ============================================================
# CCR Website environment configuration
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# SQLite for local dev. Swap to PostgreSQL in production, e.g.
# DATABASE_URL="postgresql://user:pass@host:5432/ccr"
DATABASE_URL="file:./ccr.db"

# Secret used to sign staff/admin session tokens (JWT HS256).
# Generate with:  openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string"

# Public site URL (used in emails, sitemap, structured data)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Initial admin account (used by `npm run db:seed` only) ---
SEED_ADMIN_EMAIL="coolcaserepair@gmail.com"
SEED_ADMIN_PASSWORD=""   # leave empty to have the seed generate and print one

# --- Anthropic API (AI pricing agents, Admin AI console) ---
ANTHROPIC_API_KEY=""

# --- Google Places API (real Google reviews sync) ---
# Needs "Places API (New)" enabled. Places exposes a limited review snippet set.
# For importing every Google Business Profile review, use the Google Business
# Profile API with OAuth access to the verified business location.
# Public pages filter stored reviews to visible 5-star reviews before display.
GOOGLE_PLACES_API_KEY=""
GOOGLE_PLACE_ID="ChIJT_o9vItLkWsRgHNb73gMvOA"

# --- Outgoing email (quote estimates). Without SMTP config, emails are
#     written to var/outbox/*.html so you can preview them in dev. ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="CCR Cool Case Repair <coolcaserepair@gmail.com>"

# --- POS integration (inventory stock sync) ---
# Supported: loyverse | mock
POS_PROVIDER="mock"
LOYVERSE_API_TOKEN=""
