{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "yarn install",
  "regions": ["syd1"],
  "functions": {
    "src/app/api/staff/ai/pricing/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/admin/reviews/sync/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/staff/inventory/sync/route.ts": {
      "maxDuration": 30
    }
  }
}
